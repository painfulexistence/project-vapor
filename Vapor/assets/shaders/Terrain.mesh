#version 450
#extension GL_EXT_mesh_shader : require
// Mesh-shader terrain, generation stage (Vulkan). One workgroup = one 8x8-quad
// patch of the tile the task stage amplified: a 9x9 vertex lattice sampling
// the SAME gradient-noise heightfield as the CPU TerrainWorld (trGradNoise2 /
// heightAt ported verbatim — scatter, grass and gameplay ground clamps sit on
// the CPU heights, so the math must match exactly), with shared-edge vertices
// snapped onto a coarser neighbor's lattice (payload resN/E/S/W) so adjacent
// tiles of different resolutions stay watertight without skirts.
//
// The fragment stage is RHIMain.frag itself: this shader emits its exact
// interpolant contract (locations 0-5) with the terrain material's id, so the
// mesh path shades pixel-identically to the CPU tile path (same terrain splat
// branch, same lighting).
//
// Bindings: set0 b0 CameraData, b3 TerrainMeshParams (see Terrain.task).

layout(local_size_x = 128) in;
layout(triangles, max_vertices = 81, max_primitives = 128) out;

struct CameraData {
    mat4 proj;
    mat4 view;
    mat4 invProj;
    mat4 invView;
    float nearPlane;
    float farPlane;
    vec2 _pad;
    vec3 position;
    float _pad2;
    vec4 frustumPlanes[6];
};
layout(std430, set = 0, binding = 0) readonly buffer CameraBuf { CameraData cam; };

layout(std430, set = 0, binding = 3) readonly buffer TerrainInfoBuf {
    vec4 worldParams;   // x worldSize, y tileSize, z heightScale, w noiseFrequency
    ivec4 gridParams;   // x tilesAxis, y noiseOctaves, z materialId, w seed
    ivec4 lodParams;    // xyz lod radii (tiles), w unused
};

struct TerrainPayload {
    uint tileX, tileZ;
    uint res;
    uint resN, resE, resS, resW;
};
taskPayloadSharedEXT TerrainPayload payload;

// RHIMain.frag's interpolant contract (RHIMain.vert twin).
layout(location = 0) out vec3 fragPos[];
layout(location = 1) out vec2 fragUV[];
layout(location = 2) out vec3 worldNormal[];
layout(location = 3) out vec4 worldTangent[];
layout(location = 4) flat out uint fragMaterialID[];
layout(location = 5) out vec4 instanceColor[];

// ── Heightfield noise — EXACT GLSL port of terrain_world.cpp ────────────────
float trHashNoise(int x, int y, uint seed) {
    uint h = uint(x) * 374761393u + uint(y) * 668265263u + seed * 3266489917u;
    h = (h ^ (h >> 13)) * 1274126177u;
    h ^= h >> 16;
    return float(h & 0xFFFFu) / 65535.0;
}

float trGradDot(int xi, int zi, vec2 offset, uint seed) {
    vec2 g = vec2(trHashNoise(xi, zi, seed) - 0.5, trHashNoise(xi, zi, seed ^ 0x9E3779B9u) - 0.5);
    float len = length(g);
    if (len < 1e-6) return offset.x;
    return dot(g / len, offset);
}

float trGradNoise2(vec2 p, uint seed) {
    vec2 pf = floor(p);
    vec2 f = p - pf;
    vec2 u = f * f * f * (f * (f * 6.0 - 15.0) + 10.0);  // quintic fade
    int xi = int(pf.x), zi = int(pf.y);
    float a = trGradDot(xi, zi, f, seed);
    float b = trGradDot(xi + 1, zi, f - vec2(1.0, 0.0), seed);
    float c = trGradDot(xi, zi + 1, f - vec2(0.0, 1.0), seed);
    float d = trGradDot(xi + 1, zi + 1, f - vec2(1.0, 1.0), seed);
    return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}

float heightAt(float x, float z) {
    vec2 p = vec2(x, z) * worldParams.w;
    float sum = 0.0, amp = 0.5;
    const uint seed = uint(gridParams.w);
    for (int i = 0; i < gridParams.y; i++) {
        sum += amp * trGradNoise2(p, seed + uint(i) * 101u);
        p *= 2.0;
        amp *= 0.5;
    }
    return clamp(0.5 + sum * 1.2, 0.0, 1.0) * worldParams.z;
}

void main() {
    SetMeshOutputsEXT(81u, 128u);

    const uint res = payload.res;
    const float halfW = 0.5 * worldParams.x;
    const float ts = worldParams.y;
    const float minX = float(payload.tileX) * ts - halfW;
    const float minZ = float(payload.tileZ) * ts - halfW;
    const float step = ts / float(res);

    // One vertex per invocation for the first 81 threads (9x9 lattice).
    const uint lid = gl_LocalInvocationID.x;
    if (lid < 81u) {
        const uint vx = lid % 9u;
        const uint vz = lid / 9u;
        // Global lattice coordinates on the tile: [0, res].
        uint gi = gl_WorkGroupID.x * 8u + vx;
        uint gj = gl_WorkGroupID.y * 8u + vz;

        // Edge snapping: a vertex on a tile edge shared with a coarser
        // neighbor snaps its along-edge coordinate down to the neighbor's
        // lattice (res is a power-of-two multiple of the neighbor res, so
        // integer masking is exact). Corners are lattice points of every
        // resolution and never move. Both tiles then evaluate the identical
        // world position -> identical height -> watertight seam.
        if (gi == 0u && payload.resW < res) gj = (gj / (res / payload.resW)) * (res / payload.resW);
        if (gi == res && payload.resE < res) gj = (gj / (res / payload.resE)) * (res / payload.resE);
        if (gj == 0u && payload.resN < res) gi = (gi / (res / payload.resN)) * (res / payload.resN);
        if (gj == res && payload.resS < res) gi = (gi / (res / payload.resS)) * (res / payload.resS);

        const float wx = minX + float(gi) * step;
        const float wz = minZ + float(gj) * step;
        const float h = heightAt(wx, wz);
        // Normal + slope from central differences at the tile's own step —
        // the same scheme (and therefore the same shading) as the CPU tiles.
        const float hl = heightAt(wx - step, wz), hr = heightAt(wx + step, wz);
        const float hd = heightAt(wx, wz - step), hu = heightAt(wx, wz + step);
        const vec3 n = normalize(vec3(hl - hr, 2.0 * step, hd - hu));
        const float slope01 = clamp(sqrt((hr - hl) * (hr - hl) + (hu - hd) * (hu - hd)) / (4.0 * step),
                                    0.0, 1.0);

        const vec3 world = vec3(wx, h, wz);
        gl_MeshVerticesEXT[lid].gl_Position = cam.proj * cam.view * vec4(world, 1.0);
        fragPos[lid] = world;
        fragUV[lid] = vec2(h / worldParams.z, slope01);  // (height01, slope01)
        worldNormal[lid] = n;
        worldTangent[lid] = vec4(1.0, 0.0, 0.0, 1.0);
        fragMaterialID[lid] = uint(gridParams.z);
        instanceColor[lid] = vec4(1.0);
    }

    // Two triangles per quad for the first 64 threads (8x8 quads), matching
    // the CPU tile winding (v00, v01, v11 / v00, v11, v10).
    if (lid < 64u) {
        const uint qx = lid % 8u;
        const uint qz = lid / 8u;
        const uint v00 = qz * 9u + qx;
        const uint v10 = v00 + 1u;
        const uint v01 = v00 + 9u;
        const uint v11 = v01 + 1u;
        gl_PrimitiveTriangleIndicesEXT[lid * 2u + 0u] = uvec3(v00, v01, v11);
        gl_PrimitiveTriangleIndicesEXT[lid * 2u + 1u] = uvec3(v00, v11, v10);
    }
}
